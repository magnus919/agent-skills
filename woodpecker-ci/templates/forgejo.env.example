# Copy to .env and replace every placeholder. Never commit the filled file.
WOODPECKER_HOST=https://ci.example.com
WOODPECKER_OPEN=false
WOODPECKER_ADMIN=admin-user
WOODPECKER_AGENT_SECRET=replace-with-openssl-rand-hex-32
WOODPECKER_FORGEJO=true
WOODPECKER_FORGEJO_URL=https://forge.example.com
WOODPECKER_FORGEJO_CLIENT=oauth-client-id
WOODPECKER_FORGEJO_SECRET=oauth-client-secret
WOODPECKER_MAX_WORKFLOWS=2
