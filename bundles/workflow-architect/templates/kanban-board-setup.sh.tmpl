#!/usr/bin/env bash
# Generated by workflow-architect — review before running
# Kanban board for {{BUNDLE_NAME}}
# Archetype: {{ARCHETYPE}}

set -euo pipefail

BOARD_SLUG="{{BOARD_SLUG}}"
BOARD_NAME="{{BOARD_NAME}}"

echo "Creating kanban board: $BOARD_NAME ($BOARD_SLUG)"

# Create the board
hermes kanban boards create "$BOARD_SLUG" \
  --name "$BOARD_NAME" \
  --description "Generated by workflow-architect on {{GENERATION_DATE}}" \
  --switch

echo "Board created. Switch to it with: hermes kanban boards switch $BOARD_SLUG"
echo ""
echo "To add work, create tasks for the first phase:"
echo "  hermes kanban create \"<title>\" --skill {{BUNDLE_NAME}}/{{FIRST_PHASE_SKILL}} --priority {{FIRST_PHASE_PRIORITY}}"
echo ""
echo "Task blueprints are in kanban/task-blueprints.yaml"
